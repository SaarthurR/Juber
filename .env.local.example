# Copy to .env.local and fill in from your Supabase project
# (Project Settings -> API). Never commit real secrets.

# --- Required (client + server) ---

# Supabase project URL. Used by browser, server, and middleware clients.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase anon/public key. Safe to expose in the browser; RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical site origin for OAuth redirects and share links.
# Local dev: http://localhost:3000
# Production: your Vercel domain, e.g. https://juber.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: address suggestions and driver route previews (Google Maps) ---

# Browser key restricted to exact production/preview/localhost HTTP referrers
# and to Maps JavaScript API + Places API (New). Places usage may incur charges.
NEXT_PUBLIC_GOOGLE_MAPS_PLACES_KEY=your-browser-restricted-places-key

# Separate browser key restricted to exact HTTP referrers and Maps Embed API.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your-browser-restricted-embed-key

# --- Server-only (never expose to the browser) ---

# Service role key for best-effort cancellation SMS when Twilio is configured.
# Also accepted as SUPABASE_SECRET_KEY. Omit locally unless testing SMS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Optional: best-effort cancellation SMS (Twilio) ---

# When all three are set, cancelling a ride texts pending/confirmed riders and
# cancelling a seat texts the driver. Cancellation still succeeds if SMS fails.
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15555555555
